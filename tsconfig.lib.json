{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "types": [],
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": ["src/lib/**/*", "src/app.d.ts"],
  "exclude": [
    "src/lib/paraglide/**/*",
    "src/routes/**/*",
    "tests/**/*",
    "stories/**/*"
  ]
}
